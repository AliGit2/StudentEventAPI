## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Visual Studio cache/options directory
.vs/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Files built by Visual Studio
*.obj
*.exe
*.exe.config
*.dll
*.pdb

# Rider IDE
.idea/
*.sln.iml

# Mac OSX
.DS_Store

# Node modules (if used in project)
node_modules/
npm-debug.log

# Environment variables
.env
.env.local
